        }
      ],
      "title": "Request Duration",
      "type": "graph"
    },
    {
      "datasource": "Prometheus",
      "editable": true,
      "gridPos": {
        "h": 8,
        "i": "4",
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "targets": [
        {
          "expr": "up",
          "interval": "",
          "legendFormat": "{{instance}}",
